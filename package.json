{
  "name": "tour-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @tour/web",
    "build": "npm run build -w @tour/web",
    "lint": "npm run lint -w @tour/web",
    "typecheck": "npm run typecheck -w @tour/web",
    "test": "npm run test -w @tour/web",
    "test:smoke:booking-core": "npm run test:smoke:booking-core -w @tour/web",
    "dashboard:booking-v2": "node scripts/rollout/booking-v2-dashboard.mjs",
    "report:booking-v2-go-no-go": "node scripts/rollout/booking-v2-go-no-go.mjs",
    "rollout:booking-v2-daily": "node scripts/rollout/booking-v2-daily-trigger.mjs",
    "snapshot:availability:backfill": "node scripts/rollout/backfill-availability-snapshot.mjs",
    "regression:issue-169": "bash scripts/phase12/run-issue-169-regression-pack.sh",
    "regression:issue-210:booking-cancel": "bash scripts/phase12/run-issue-210-booking-cancel-verification-pack.sh",
    "regression:issue-217:plan-linkage": "bash scripts/phase12/run-issue-217-plan-linkage-guardrails.sh",
    "preflight:schema-drift": "node scripts/production-schema-drift-preflight.mjs",
    "readiness:snapshot": "node scripts/readiness/generate-live-state-snapshot.mjs",
    "readiness:check": "node scripts/readiness/check-snapshot-freshness.mjs",
    "taxonomy:check": "node scripts/taxonomy/check-labels.mjs",
    "audit:public-booking": "node scripts/audit-public-booking-v2.mjs",
    "repair:booking-plans:dry-run": "node --env-file=.env scripts/admin/audit-or-repair-booking-plans.mjs",
    "qa:auth-env:check": "node --env-file=qa-test-secrets/.env.qa.local scripts/qa/validate-auth-env.mjs --target=production"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "dotenv": "^17.4.1",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "supabase": "^2.87.2",
    "typescript": "6.0.2"
  },
  "overrides": {
    "eslint-config-next": "15.5.15"
  },
  "engines": {
    "node": ">=22"
  }
}
