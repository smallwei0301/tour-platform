# ========================================
# Tour Platform Environment Configuration
# ========================================

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ========================================
# Supabase Configuration
# ========================================
# Client-side (公開)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side (機密)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ========================================
# ECPay 金流配置
# ========================================
# 環境切換: sandbox (測試) | production (正式)
ECPAY_ENV=sandbox

# 沙箱環境 (ECPay 提供的測試帳號)
ECPAY_MERCHANT_ID=3002607
ECPAY_HASH_KEY=pwFHCqoQZGmho4w6
ECPAY_HASH_IV=EkRm7iFT261dpevs
ECPAY_CALLBACK_URL=https://your-domain.com/api/payments/ecpay/callback

# 正式環境（上線前更換並設置 ECPAY_ENV=production）
# ECPAY_MERCHANT_ID=your-production-merchant-id
# ECPAY_HASH_KEY=your-production-hash-key
# ECPAY_HASH_IV=your-production-hash-iv

# ========================================
# Admin 管理後台
# ========================================
ADMIN_ACCESS_TOKEN=your-secure-admin-token
ADMIN_EMAIL_ALLOWLIST=admin@example.com

# ========================================
# Email 通知 (Resend)
# ========================================
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Tour Platform <noreply@your-domain.com>

# ========================================
# LINE Notify 通知
# ========================================
LINE_NOTIFY_ACCESS_TOKEN=your-line-notify-token

# ========================================
# Sentry 錯誤監控
# ========================================
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=your-sentry-auth-token
