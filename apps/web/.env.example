# ========================================
# Tour Platform Environment Configuration (Template Only)
# ========================================
# ⚠️ Do NOT put real secrets in this file.

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# V2 booking flow is the default (code defaults to true when unset).
# Production Vercel should set this explicitly to "true". Set to "false" to force legacy fallback.
NEXT_PUBLIC_BOOKING_V2_ENABLED=true

# ========================================
# Supabase Configuration
# ========================================
# Client-side (public metadata)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key-placeholder

# Server-side (secret)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-server-anon-key-placeholder
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-placeholder

# ========================================
# ECPay Configuration
# ========================================
# sandbox | production
ECPAY_ENV=sandbox
ECPAY_MERCHANT_ID=your-merchant-id-placeholder
ECPAY_HASH_KEY=your-hash-key-placeholder
ECPAY_HASH_IV=your-hash-iv-placeholder
ECPAY_CALLBACK_URL=https://your-domain.com/api/payments/ecpay/callback

# ========================================
# Admin Console
# ========================================
ADMIN_ACCESS_TOKEN=your-admin-access-token-placeholder
ADMIN_EMAIL_ALLOWLIST=admin@example.com

# ========================================
# OAuth / Integrations
# ========================================
GOOGLE_CLIENT_ID=your-google-client-id-placeholder
GOOGLE_CLIENT_SECRET=your-google-client-secret-placeholder

# ========================================
# Notifications / Monitoring
# ========================================
RESEND_API_KEY=your-resend-api-key-placeholder
EMAIL_FROM=Tour Platform <noreply@your-domain.com>
# DEPRECATED: LINE Notify was shut down by LINE on 2025-03-31 and no longer works.
# Ops notifications now use the LINE Messaging API (see LINE section below).
LINE_NOTIFY_ACCESS_TOKEN=your-line-notify-token-placeholder
SENTRY_DSN=https://public@example.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=your-sentry-auth-token-placeholder

# ========================================
# LINE Messaging API / LIFF (#302b)
# Rollout flags default OFF — see docs/operations/issue-179-line-liff-rollout-support-sop.md
# ========================================
# Master kill-switch for all Messaging API egress (ops + per-traveler push)
LINE_MESSAGING_ENABLED=0
# Per-traveler push (booking/payment/cancel/refund/reminder); requires messaging enabled + a binding
LINE_PUSH_ENABLED=0
# Real LIFF login on /booking/line (off = legacy query-param handoff)
NEXT_PUBLIC_LINE_LIFF_ENABLED=0
# Messaging API channel (push/reply bearer + webhook signature secret)
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token-placeholder
LINE_CHANNEL_SECRET=your-line-channel-secret-placeholder
# Target group for ops/admin notifications (empty = skip)
LINE_OPS_GROUP_ID=
# LINE Login channel (idToken aud verification) + LIFF app id
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
NEXT_PUBLIC_LIFF_ID=
