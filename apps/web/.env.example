# ========================================
# Tour Platform Environment Configuration
# ========================================

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ========================================
# Supabase Configuration
# ========================================
# Client-side (公開)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side (機密)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ========================================
# ECPay 金流配置
# ========================================
# 環境切換: sandbox (測試) | production (正式)
ECPAY_ENV=sandbox

# 請填入你自己的 ECPay 測試或正式商戶資料（不要提交真值）
ECPAY_MERCHANT_ID=your-ecpay-merchant-id
ECPAY_HASH_KEY=your-ecpay-hash-key
ECPAY_HASH_IV=your-ecpay-hash-iv
ECPAY_CALLBACK_URL=https://your-domain.com/api/payments/ecpay/callback

# ========================================
# Admin 管理後台
# ========================================
ADMIN_ACCESS_TOKEN=your-secure-admin-token
ADMIN_EMAIL_ALLOWLIST=admin@example.com

# ========================================
# Email 通知 (Resend)
# ========================================
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Tour Platform <noreply@your-domain.com>

# ========================================
# LINE Notify 通知
# ========================================
LINE_NOTIFY_ACCESS_TOKEN=your-line-notify-token

# ========================================
# Sentry 錯誤監控
# ========================================
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=your-sentry-auth-token
