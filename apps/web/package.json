{
  "name": "@tour/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint app src --ignore-pattern '.next/**'",
    "test": "node --test tests/**/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:smoke": "playwright test --workers=1 e2e/issue1294-slot-range-semantics.spec.ts e2e/issue1269-step3-ecpay-only-payment-ui.spec.ts",
    "test:smoke:v2-core": "node --test tests/api/v2-available-slots.test.mjs tests/api/v2-booking-draft-checkout.test.mjs tests/api/booking-state.test.mjs tests/api/ecpay-callback.test.mjs tests/api/v2-route-contract-smoke.test.mjs",
    "test:smoke:booking-core": "npm run test:smoke:v2-core",
    "test:smoke:guide-blackout": "node --test --test-name-pattern='Blackout|validateSlotAvailability detects blackout conflicts' tests/slot-generator.test.mjs && node --test tests/api/v2-guide-blackout-contract.test.mjs",
    "test:smoke:admin-pos-line": "node --test tests/api/v2-admin-pos-line-regression.test.mjs",
    "test:smoke:phase12-full": "bash ../../scripts/phase12/run-full-regression.sh",
    "test:smoke:public-booking-regression": "node --test tests/api/booking-v2-public-booking-regression.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.47.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.53.0",
    "@types/react": "19.2.14",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "^15.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.10.0",
    "typescript": "6.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.3"
  },
  "engines": {
    "node": ">=22"
  }
}