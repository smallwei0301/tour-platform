# QA auth/login environment template — copy to qa-test-secrets/.env.qa.local and fill locally.
# Never commit real tokens, passwords, service-role keys, or Vercel access tokens.

# Deployment targets
NEXT_PUBLIC_APP_URL=https://your-preview-or-production-domain.example
NEXT_PUBLIC_SITE_URL=https://your-preview-or-production-domain.example
VERCEL_ORG_ID=team_xxx
VERCEL_PROJECT_ID=prj_xxx
VERCEL_TOKEN=replace_with_local_vercel_token_only

# Supabase / database
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# Admin backstage login
ADMIN_ACCESS_TOKEN=replace_with_min_16_chars_admin_token
ADMIN_EMAIL_ALLOWLIST=qa-admin@example.com
QA_ADMIN_EMAIL=qa-admin@example.com
QA_ADMIN_TOKEN=replace_with_same_value_as_ADMIN_ACCESS_TOKEN

# Guide backstage login
GUIDE_SESSION_SECRET=replace_with_min_32_chars_guide_session_secret
QA_GUIDE_EMAIL=qa-guide@example.com
QA_GUIDE_PASSWORD=replace_with_qa_guide_password
# Optional legacy / invite-path checks
QA_GUIDE_ID=
QA_GUIDE_INVITE_TOKEN=
GUIDE_AUTH_SUPABASE_TIMEOUT_MS=8000

# Optional feature/report flags
GUIDE_DASHBOARD_REPORT_TIER=free
